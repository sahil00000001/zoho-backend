generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────
// Enums
// ─────────────────────────────────────────

enum Role {
  EMPLOYEE
  MANAGER
  HR
  ADMIN
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LATE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum RegularizationStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─────────────────────────────────────────
// Models
// ─────────────────────────────────────────

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}

model User {
  id              String    @id @default(uuid())
  employeeId      String    @unique
  email           String    @unique
  firstName       String
  lastName        String
  role            Role      @default(EMPLOYEE)
  designation     String?
  phoneNumber     String?
  joiningDate     DateTime?
  address         String?
  profilePhotoUrl String?
  isActive        Boolean   @default(true)
  departmentId    String?
  managerId       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  department    Department?    @relation(fields: [departmentId], references: [id])
  manager       User?          @relation("ManagerSubordinates", fields: [managerId], references: [id])
  subordinates  User[]         @relation("ManagerSubordinates")
  attendances            Attendance[]
  leaves                 Leave[]
  refreshTokens          RefreshToken[]
  otps                   OTP[]
  regularizations        AttendanceRegularization[] @relation("RegularizationEmployee")
  regularizationReviews  AttendanceRegularization[] @relation("RegularizationReviewer")
}

model OTP {
  id        String   @id @default(uuid())
  userId    String
  code      String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Attendance {
  id               String           @id @default(uuid())
  userId           String
  date             DateTime         @db.Date
  checkInTime      DateTime?
  checkInLat       Float?
  checkInLng       Float?
  checkInAddress   String?
  checkOutTime     DateTime?
  checkOutLat      Float?
  checkOutLng      Float?
  checkOutAddress  String?
  workHours        Float?
  overtimeHours    Float?
  isWFH            Boolean          @default(false)
  status           AttendanceStatus @default(PRESENT)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user            User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  regularizations AttendanceRegularization[]

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model AttendanceRegularization {
  id                String               @id @default(uuid())
  userId            String
  attendanceId      String?
  date              DateTime             @db.Date
  reason            String
  requestedCheckIn  DateTime?
  requestedCheckOut DateTime?
  status            RegularizationStatus @default(PENDING)
  reviewedBy        String?
  reviewedAt        DateTime?
  reviewNote        String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  user       User        @relation("RegularizationEmployee", fields: [userId], references: [id], onDelete: Cascade)
  attendance Attendance? @relation(fields: [attendanceId], references: [id])
  reviewer   User?       @relation("RegularizationReviewer", fields: [reviewedBy], references: [id])

  @@index([userId])
  @@index([date])
  @@index([status])
}

model LeaveType {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  maxDays     Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leaves Leave[]
}

model Leave {
  id          String      @id @default(uuid())
  userId      String
  leaveTypeId String
  startDate   DateTime    @db.Date
  endDate     DateTime    @db.Date
  reason      String
  status      LeaveStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@index([userId])
  @@index([status])
}
