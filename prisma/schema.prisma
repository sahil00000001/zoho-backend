generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────
// Enums
// ─────────────────────────────────────────

enum Role {
  EMPLOYEE
  MANAGER
  HR
  ADMIN
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LATE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum RegularizationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum HolidayType {
  NATIONAL
  COMPANY
  OPTIONAL
}

enum CompOffStatus {
  EARNED
  APPROVED
  USED
  EXPIRED
}

// ─────────────────────────────────────────
// Models
// ─────────────────────────────────────────

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}

model User {
  id              String    @id @default(uuid())
  employeeId      String    @unique
  email           String    @unique
  firstName       String
  lastName        String
  role            Role      @default(EMPLOYEE)
  designation     String?
  phoneNumber     String?
  joiningDate     DateTime?
  address         String?
  profilePhotoUrl String?
  isActive        Boolean   @default(true)
  departmentId    String?
  managerId       String?
  customRoleId    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  department    Department?    @relation(fields: [departmentId], references: [id])
  manager       User?          @relation("ManagerSubordinates", fields: [managerId], references: [id])
  subordinates  User[]         @relation("ManagerSubordinates")
  customRole    CustomRole?    @relation(fields: [customRoleId], references: [id])
  attendances            Attendance[]
  leaves                 Leave[]
  refreshTokens          RefreshToken[]
  otps                   OTP[]
  regularizations        AttendanceRegularization[] @relation("RegularizationEmployee")
  regularizationReviews  AttendanceRegularization[] @relation("RegularizationReviewer")
  compOffs         CompOff[] @relation
  compOffApprovals CompOff[] @relation("CompOffApprover")

  onboardingTasks  OnboardingTask[]
  assetAssignments AssetAssignment[]
  assignedAssets   AssetAssignment[] @relation("AssetAssigner")
  itProvisions     ITProvision[]

  profile          UserProfile?
  skills           Skill[]
  certifications   Certification[]
  kraDocuments     KRADocument[]
  announcements    Announcement[]   @relation("AnnouncementAuthor")

  @@index([managerId])
  @@index([isActive])
  @@index([departmentId])
  @@index([isActive, role])
  @@index([isActive, managerId])
}

model OTP {
  id        String   @id @default(uuid())
  userId    String
  code      String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Attendance {
  id               String           @id @default(uuid())
  userId           String
  date             DateTime         @db.Date
  checkInTime      DateTime?
  checkInLat       Float?
  checkInLng       Float?
  checkInAddress   String?
  checkOutTime     DateTime?
  checkOutLat      Float?
  checkOutLng      Float?
  checkOutAddress  String?
  workHours        Float?
  overtimeHours    Float?
  isWFH            Boolean          @default(false)
  status           AttendanceStatus @default(PRESENT)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user            User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  regularizations AttendanceRegularization[]

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model AttendanceRegularization {
  id                String               @id @default(uuid())
  userId            String
  attendanceId      String?
  date              DateTime             @db.Date
  reason            String
  requestedCheckIn  DateTime?
  requestedCheckOut DateTime?
  status            RegularizationStatus @default(PENDING)
  reviewedBy        String?
  reviewedAt        DateTime?
  reviewNote        String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  user       User        @relation("RegularizationEmployee", fields: [userId], references: [id], onDelete: Cascade)
  attendance Attendance? @relation(fields: [attendanceId], references: [id])
  reviewer   User?       @relation("RegularizationReviewer", fields: [reviewedBy], references: [id])

  @@index([userId])
  @@index([date])
  @@index([status])
}

model LeaveType {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  maxDays     Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leaves Leave[]
}

model Leave {
  id          String      @id @default(uuid())
  userId      String
  leaveTypeId String
  startDate   DateTime    @db.Date
  endDate     DateTime    @db.Date
  reason      String
  status      LeaveStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([leaveTypeId])
  @@index([userId, status])
  @@index([status, startDate, endDate])
}

model Holiday {
  id        String      @id @default(uuid())
  name      String
  date      DateTime    @db.Date
  type      HolidayType @default(COMPANY)
  year      Int
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([date])
  @@index([year])
}

model CompOff {
  id         String        @id @default(uuid())
  userId     String
  reason     String
  earnedDate DateTime      @db.Date
  expiresAt  DateTime      @db.Date
  status     CompOffStatus @default(EARNED)
  approvedBy String?
  approvedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  approver User? @relation("CompOffApprover", fields: [approvedBy], references: [id])

  @@index([userId])
  @@index([status])
}

// ─────────────────────────────────────────
// Onboarding Enums
// ─────────────────────────────────────────

enum AssetType {
  LAPTOP
  ACCESS_CARD
  MONITOR
  KEYBOARD
  MOUSE
  PHONE
  OTHER
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  UNDER_MAINTENANCE
  RETIRED
}

enum OnboardingTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum ITProvisionStatus {
  PENDING
  IN_PROGRESS
  DONE
  BLOCKED
}

// ─────────────────────────────────────────
// Onboarding Models
// ─────────────────────────────────────────

model OnboardingTask {
  id              String               @id @default(uuid())
  userId          String
  title           String
  description     String?
  category        String
  dueDay          Int
  status          OnboardingTaskStatus @default(PENDING)
  completedAt     DateTime?
  notes           String?
  responsibleRole String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Asset {
  id           String      @id @default(uuid())
  type         AssetType
  name         String
  serialNumber String?     @unique
  model        String?
  status       AssetStatus @default(AVAILABLE)
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  assignments AssetAssignment[]
}

model AssetAssignment {
  id           String    @id @default(uuid())
  assetId      String
  userId       String
  assignedAt   DateTime  @default(now())
  returnedAt   DateTime?
  condition    String?
  notes        String?
  assignedById String?

  asset      Asset  @relation(fields: [assetId], references: [id])
  user       User   @relation(fields: [userId], references: [id])
  assignedBy User?  @relation("AssetAssigner", fields: [assignedById], references: [id])

  @@index([userId])
  @@index([assetId])
}

model ITProvision {
  id          String            @id @default(uuid())
  userId      String
  item        String
  status      ITProvisionStatus @default(PENDING)
  notes       String?
  completedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ─────────────────────────────────────────
// Profile Models
// ─────────────────────────────────────────

model UserProfile {
  id                String    @id @default(uuid())
  userId            String    @unique
  photoUrl          String?   @db.Text
  bio               String?
  address           String?
  city              String?
  state             String?
  pincode           String?
  emergencyName     String?
  emergencyPhone    String?
  emergencyRelation String?
  dateOfBirth       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id])
}

model Skill {
  id        String   @id @default(uuid())
  userId    String
  name      String
  level     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Certification {
  id           String    @id @default(uuid())
  userId       String
  name         String
  issuer       String?
  issueDate    DateTime?
  expiryDate   DateTime?
  credentialId String?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id])
}

model KRADocument {
  id         String   @id @default(uuid())
  userId     String
  title      String
  period     String?
  fileUrl    String   @db.Text
  fileName   String
  fileSize   Int?
  mimeType   String?
  uploadedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

// ─────────────────────────────────────────
// RBAC — Custom Roles
// ─────────────────────────────────────────

model CustomRole {
  id                  String   @id @default(cuid())
  name                String   @unique
  description         String?
  basePermissionLevel Role     // EMPLOYEE | MANAGER | HR | ADMIN — controls what API calls they can make
  isSystem            Boolean  @default(false)
  color               String   @default("#6366f1")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  modulePermissions   RoleModulePermission[]
  users               User[]
}

model RoleModulePermission {
  id           String     @id @default(cuid())
  customRoleId String
  moduleKey    String     // 'attendance' | 'leaves' | 'onboarding' | etc.
  canAccess    Boolean    @default(true)
  customRole   CustomRole @relation(fields: [customRoleId], references: [id], onDelete: Cascade)

  @@unique([customRoleId, moduleKey])
}

// ─────────────────────────────────────────
// Audit & Error Logs
// ─────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  userEmail  String?
  userName   String?
  action     String   // e.g. 'CREATE_USER', 'APPROVE_LEAVE', 'CHECK_IN'
  module     String   // e.g. 'users', 'leaves', 'attendance'
  resourceId String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([module])
  @@index([createdAt])
}

model ErrorLog {
  id         String   @id @default(cuid())
  message    String
  stack      String?
  endpoint   String?
  method     String?
  userId     String?
  statusCode Int?
  createdAt  DateTime @default(now())
}

// ─────────────────────────────────────────
// Announcements
// ─────────────────────────────────────────

enum AnnouncementType {
  COMPANY
  DEPARTMENT
}

enum AnnouncementPriority {
  HIGH
  NORMAL
  LOW
}

model Announcement {
  id           String               @id @default(uuid())
  title        String
  content      String               @db.Text
  type         AnnouncementType     @default(COMPANY)
  priority     AnnouncementPriority @default(NORMAL)
  departmentId String?
  expiresAt    DateTime?
  isPinned     Boolean              @default(false)
  createdById  String
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  createdBy    User                 @relation("AnnouncementAuthor", fields: [createdById], references: [id])

  @@index([createdAt])
  @@index([isPinned, createdAt])
  @@index([type, departmentId])
}
