# ── Database (Supabase) ────────────────────────────────────────────
# Transaction pooler URL (port 6543) — used at runtime / on Vercel
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"

# Direct connection URL (port 5432) — used only by Prisma migrate
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].supabase.com:5432/postgres"

# ── JWT ───────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="your-super-secret-access-token-key-min-64-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-token-key-min-64-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── OTP ───────────────────────────────────────────────────────────
OTP_EXPIRES_MINUTES=10

# ── Email (SMTP) ──────────────────────────────────────────────────
# Option A: Gmail (enable App Password in Google Account settings)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-gmail@gmail.com"
SMTP_PASS="your-gmail-app-password"
SMTP_FROM="Employee Portal <your-gmail@gmail.com>"

# ── App ───────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3000
CORS_ORIGIN="*"
